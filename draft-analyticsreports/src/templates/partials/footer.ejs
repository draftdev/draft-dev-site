<footer class="brand-gradient-bg mt-16">
  <div class="max-w-7xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between">
      <p class="text-sm text-brand-200">
        <%= clientName %> Analytics Report - <%= reportMonth %>
      </p>
      <% if (previousReports && previousReports.length > 0) { %>
        <div class="text-sm text-brand-200 previous-reports-nav">
          <span class="mr-2">Previous Reports:</span>
          <% previousReports.slice(0, 3).forEach(function(report, index) { %>
            <a href="<%= report.filename %>" class="text-brand-100 hover:text-white underline transition-colors">
              <%= report.month %>
            </a>
            <% if (index < Math.min(previousReports.length - 1, 2)) { %>
              <span class="mx-1">|</span>
            <% } %>
          <% }); %>
          <% if (previousReports.length > 3) { %>
            <span class="ml-1 text-brand-300">+<%= previousReports.length - 3 %> more</span>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</footer>
