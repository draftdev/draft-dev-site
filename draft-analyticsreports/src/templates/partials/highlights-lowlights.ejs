<%
  // Filter notes to get highlights and lowlights separately
  const highlights = (notes || []).filter(note => note.section === 'highlights');
  const lowlights = (notes || []).filter(note => note.section === 'lowlights');

  // Helper function to extract URLs from text
  function extractUrls(text) {
    if (!text) return [];
    const urlRegex = /(https?:\/\/[^\s<>"']+)/g;
    return text.match(urlRegex) || [];
  }

  // Helper function to remove URLs from text
  function removeUrls(text) {
    if (!text) return '';
    const urlRegex = /(https?:\/\/[^\s<>"']+)/g;
    return text.replace(urlRegex, '').replace(/\s+/g, ' ').trim();
  }

  // Helper function to format text with bullet points
  function formatTextWithBullets(text) {
    if (!text) return '';

    // Split by newlines to check if we have multiple lines
    const lines = text.split(/\n+/).map(line => line.trim()).filter(line => line.length > 0);

    // If there's only one line, return it as-is
    if (lines.length === 1) {
      return text;
    }

    // Multiple lines - convert to a bullet list
    return '<ul class="list-disc list-inside space-y-1">' +
           lines.map(line => `<li>${line}</li>`).join('') +
           '</ul>';
  }

  // Determine grid classes - max 2 per row
  function getGridClasses(count, index) {
    if (count === 1) {
      return 'col-span-full';
    }
    return 'col-span-1';
  }

  // Generate unique ID for lightbox
  let imageCounter = 0;
  function getImageId() {
    return 'lightbox-img-' + (imageCounter++);
  }
%>

<% if (highlights.length > 0 || lowlights.length > 0) { %>

<!-- Lightbox Overlay -->
<div id="lightbox-overlay" class="fixed inset-0 bg-black bg-opacity-80 z-50 hidden items-center justify-center p-4" onclick="closeLightbox(event)">
  <div class="relative max-w-5xl max-h-full">
    <button onclick="closeLightbox(event)" class="absolute -top-10 right-0 text-white text-3xl font-light hover:text-brand-200 transition-colors">&times;</button>
    <img id="lightbox-image" src="" alt="Screenshot" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl" onclick="event.stopPropagation()"/>
  </div>
</div>

<script>
  function openLightbox(imageSrc) {
    const overlay = document.getElementById('lightbox-overlay');
    const image = document.getElementById('lightbox-image');
    image.src = imageSrc;
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox(event) {
    if (event) event.stopPropagation();
    const overlay = document.getElementById('lightbox-overlay');
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeLightbox();
    }
  });
</script>

<% if (highlights.length > 0) { %>
<section class="py-10">
  <h2 class="brand-section-title mb-8">Highlights</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% highlights.forEach(function(highlight, index) { %>
      <%
        const hasScreenshot = (highlight.screenshotFile && screenshots[highlight.screenshotFile]) || highlight.embeddedImage;
        const imageSource = highlight.embeddedImage || (highlight.screenshotFile && screenshots[highlight.screenshotFile]);
        const imageId = getImageId();
      %>
      <%
        // Extract URLs from note text
        const urlsInNote = extractUrls(highlight.note);
        const textWithoutUrls = removeUrls(highlight.note);
        const allUrls = [...urlsInNote];
        if (highlight.url && !allUrls.includes(highlight.url)) {
          allUrls.push(highlight.url);
        }
      %>
      <div class="brand-card overflow-hidden flex flex-col <%= getGridClasses(highlights.length, index) %>">
        <!-- Upper section: Text content -->
        <div class="p-5">
          <% if (highlight.title) { %>
            <h3 class="text-base font-semibold text-brand-900 mb-2"><%= highlight.title %></h3>
          <% } %>
          <% if (textWithoutUrls) { %>
            <div class="text-sm text-brand-700 leading-relaxed"><%- formatTextWithBullets(textWithoutUrls) %></div>
          <% } %>
          <% if (allUrls.length > 0) { %>
            <div class="mt-3">
              <% if (allUrls.length === 1) { %>
                <a href="<%= allUrls[0] %>" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-800 underline text-sm break-all cursor-pointer">
                  <%= allUrls[0] %>
                </a>
              <% } else { %>
                <ul class="list-disc list-inside space-y-1">
                  <% allUrls.forEach(function(url) { %>
                    <li>
                      <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-800 underline text-sm break-all cursor-pointer">
                        <%= url %>
                      </a>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </div>
          <% } %>
        </div>

        <!-- Lower section: Screenshot(s) (optional) - clickable to open lightbox -->
        <% if (hasScreenshot) { %>
          <div class="bg-brand-50 border-t border-brand-100 flex-grow flex items-stretch justify-center overflow-hidden">
            <img
              id="<%= imageId %>"
              src="<%= imageSource %>"
              alt="<%= highlight.title || 'Highlight screenshot' %>"
              class="w-full h-full cursor-pointer hover:opacity-95 transition-opacity duration-200"
              style="object-fit: cover;"
              onclick="openLightbox('<%= imageSource %>')"
            />
          </div>
        <% } %>
        <!-- Additional screenshots (if available) -->
        <% if (highlight.screenshots && highlight.screenshots.length > 1) { %>
          <% for (let i = 1; i < highlight.screenshots.length; i++) { %>
            <% const additionalImageId = getImageId(); %>
            <div class="bg-brand-50 border-t border-brand-100 flex-grow flex items-stretch justify-center overflow-hidden">
              <img
                id="<%= additionalImageId %>"
                src="<%= highlight.screenshots[i].data %>"
                alt="<%= highlight.title || 'Highlight screenshot' %>"
                class="w-full h-full cursor-pointer hover:opacity-95 transition-opacity duration-200"
                style="object-fit: cover;"
                onclick="openLightbox('<%= highlight.screenshots[i].data %>')"
              />
            </div>
          <% } %>
        <% } %>
      </div>
    <% }); %>
  </div>
</section>
<% } %>

<% if (lowlights.length > 0) { %>
<section class="py-10">
  <h2 class="brand-section-title mb-8">Lowlights</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% lowlights.forEach(function(lowlight, index) { %>
      <%
        const hasScreenshot = (lowlight.screenshotFile && screenshots[lowlight.screenshotFile]) || lowlight.embeddedImage;
        const imageSource = lowlight.embeddedImage || (lowlight.screenshotFile && screenshots[lowlight.screenshotFile]);
        const imageId = getImageId();
      %>
      <%
        // Extract URLs from note text
        const urlsInNote = extractUrls(lowlight.note);
        const textWithoutUrls = removeUrls(lowlight.note);
        const allUrls = [...urlsInNote];
        if (lowlight.url && !allUrls.includes(lowlight.url)) {
          allUrls.push(lowlight.url);
        }
      %>
      <div class="brand-card overflow-hidden flex flex-col <%= getGridClasses(lowlights.length, index) %>">
        <!-- Upper section: Text content -->
        <div class="p-5">
          <% if (lowlight.title) { %>
            <h3 class="text-base font-semibold text-brand-900 mb-2"><%= lowlight.title %></h3>
          <% } %>
          <% if (textWithoutUrls) { %>
            <div class="text-sm text-brand-700 leading-relaxed"><%- formatTextWithBullets(textWithoutUrls) %></div>
          <% } %>
          <% if (allUrls.length > 0) { %>
            <div class="mt-3">
              <% if (allUrls.length === 1) { %>
                <a href="<%= allUrls[0] %>" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-800 underline text-sm break-all cursor-pointer">
                  <%= allUrls[0] %>
                </a>
              <% } else { %>
                <ul class="list-disc list-inside space-y-1">
                  <% allUrls.forEach(function(url) { %>
                    <li>
                      <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-800 underline text-sm break-all cursor-pointer">
                        <%= url %>
                      </a>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </div>
          <% } %>
        </div>

        <!-- Lower section: Screenshot(s) (optional) - clickable to open lightbox -->
        <% if (hasScreenshot) { %>
          <div class="bg-brand-50 border-t border-brand-100 flex-grow flex items-stretch justify-center overflow-hidden">
            <img
              id="<%= imageId %>"
              src="<%= imageSource %>"
              alt="<%= lowlight.title || 'Lowlight screenshot' %>"
              class="w-full h-full cursor-pointer hover:opacity-95 transition-opacity duration-200"
              style="object-fit: cover;"
              onclick="openLightbox('<%= imageSource %>')"
            />
          </div>
        <% } %>
        <!-- Additional screenshots (if available) -->
        <% if (lowlight.screenshots && lowlight.screenshots.length > 1) { %>
          <% for (let i = 1; i < lowlight.screenshots.length; i++) { %>
            <% const additionalImageId = getImageId(); %>
            <div class="bg-brand-50 border-t border-brand-100 flex-grow flex items-stretch justify-center overflow-hidden">
              <img
                id="<%= additionalImageId %>"
                src="<%= lowlight.screenshots[i].data %>"
                alt="<%= lowlight.title || 'Lowlight screenshot' %>"
                class="w-full h-full cursor-pointer hover:opacity-95 transition-opacity duration-200"
                style="object-fit: cover;"
                onclick="openLightbox('<%= lowlight.screenshots[i].data %>')"
              />
            </div>
          <% } %>
        <% } %>
      </div>
    <% }); %>
  </div>
</section>
<% } %>

<% } %>
